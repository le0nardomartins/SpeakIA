{
  "app": {
    "name": "SpeakAI",
    "defaultLanguageId": "en-US",
    "defaultModeId": "conversation",
    "defaultVoiceId": "JBFqnCBsd6RMkjVDRZzb",
    "defaultThemeId": "studio",
    "defaultDifficultyId": "beginner",
    "defaultAssistantName": "Ari"
  },
  "providers": {
    "openai": {
      "baseUrl": "https://api.openai.com/v1",
      "transcriptionModel": "gpt-4o-mini-transcribe",
      "conversationModel": "gpt-5-mini",
      "grammarModel": "gpt-5-mini",
      "summaryModel": "gpt-5-mini",
      "conversationTemperature": 0.7
    },
    "elevenlabs": {
      "baseUrl": "https://api.elevenlabs.io/v1",
      "modelId": "eleven_multilingual_v2",
      "outputFormat": "mp3_44100_128",
      "voiceSettings": {
        "stability": 0.45,
        "similarity_boost": 0.75,
        "style": 0.25,
        "use_speaker_boost": true
      }
    }
  },
  "prompts": {
    "speechBaseEnglish": "You are {{assistantName}}, a friendly conversation partner. Have a natural, engaging conversation with the user. CRITICAL RULES — follow these exactly:\n1. You MUST respond EXCLUSIVELY in the training language specified below. Never switch to another language, never mention another language, never offer language options.\n2. Keep replies concise and conversational. Ask one follow-up question to keep the chat alive.\n3. Do NOT mention grammar, correction, language practice modes, or anything meta about learning. Grammar is checked silently in the background — never acknowledge or discuss it.\n4. Behave like a native speaker having a casual friendly chat on any topic the user brings up.\n5. NEVER use hyphens (-), em dashes (—), en dashes (–), or any kind of dash character in your responses. NEVER use emojis of any kind. Write in plain sentences only.",
    "grammarCompanionEnglish": "You are {{assistantName}}. Have a natural conversation with the user.",
    "talkSummaryEnglish": "Create a short summary of this conversation in up to 5 lines. Focus on user goals, frequent mistakes, requested adjustments, and preferences that help future conversations."
  },
  "languages": [
    { "id": "en-US", "label": "English (US)",              "iso6391": "en" },
